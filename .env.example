# Your Torn API key that can read your company data (director key / proper access)
TORN_API_KEY=PUT_YOUR_KEY_HERE

# Optional: lock down the web endpoints so only you can use them
ADMIN_TOKEN=change_me_long_random

# If you have multiple companies, list their IDs (comma-separated)
# If blank, the app will still work, but company listing depends on what Torn returns for your key.
COMPANY_IDS=12345,67890

# Render port is automatic, but local dev uses 5000
PORT=5000
